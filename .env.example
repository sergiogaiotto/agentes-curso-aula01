# Copie este arquivo para .env e preencha com seus valores reais
OPENAI_API_KEY=

# Modelo do LLM (trocável — começamos com um modelo eficiente da OpenAI)
OPENAI_MODEL=gpt-4o-mini

# Langfuse (pegue as chaves em Settings > API Keys no painel)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

LANGFUSE_HOST=https://cloud.langfuse.com

# PostgreSQL + pgvector (RAG e memória) — note o +psycopg na URL
DATABASE_URL=postgresql+psycopg://usuario:senha@host:5432/banco

# Memória durável no Postgres (1 = usa PostgresSaver; vazio = memória do processo)
USE_PG_MEMORY=

# Chave de uma integração externa (exemplo — troque pela sua API real)
# MINHA_API_KEY=...
